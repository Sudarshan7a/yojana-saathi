# Google AI
GOOGLE_API_KEY=your_google_api_key_here

# Clerk Auth
CLERK_SECRET_KEY=your_clerk_secret_key_here

# Admin
ADMIN_TOKEN=your_admin_token_here

# Email (placeholder for v2)
RESEND_API_KEY=

# Database
DATABASE_URL=sqlite:///./metadata.db

# Vector DB
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_COLLECTION_NAME=india_schemes

# API
API_TITLE=YojnaSaathi API
API_VERSION=1.0.0

# RAG Settings
EMBEDDING_MODEL=models/embedding-001
LLM_MODEL=gemini-1.5-flash
TOP_K=15
TEMPERATURE=0.4

# Chunking (for scheme ingestion)
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Sync
SITEMAP_URL=https://www.myscheme.gov.in/sitemap.xml
SYNC_BATCH_SIZE=50
SYNC_DELAY_SECONDS=1

# File limits
MAX_FILE_SIZE_MB=10
